{
  "configurations": [
      {
          "name": "Linux",
          "includePath": [
              "${workspaceFolder}/**",
              "${workspaceFolder}/vendor/**",
              "${workspaceFolder}/core/src"
          ],
          "defines": [],
          "compilerPath": "/usr/bin/c++",                    // Make sure this is same as used by cmake
          "cStandard": "c17",
          "cppStandard": "c++23",
          "intelliSenseMode": "linux-gcc-x64",
          "compileCommands": "${workspaceFolder}/core/build/compile_commands.json"  // set(CMAKE_EXPORT_COMPILE_COMMANDS ON) in CMakeLists.txt
      }
  ],
  "version": 4
}