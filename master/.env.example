# NexGen Master Configuration
# --------------------------------

# MOCK SETTINGS
MOCK_SERVICES=true

# OPENAI SDK COMPATIBILITY
# Change this to use different models dynamically. e.g. "gpt-4o", "llama3.2", "qwen-3.5_4B_Q4_K_M"
OPENAI_MODEL_NAME=llama3.2
OPENAI_API_KEY=dummy_key_or_actual_key
# Use http://localhost:11434/v1 for Ollama, or https://api.openai.com/v1 for OpenAI directly
OPENAI_BASE_URL=http://localhost:11434/v1

# SESSION CACHE
REDIS_URL=redis://localhost:6379/0